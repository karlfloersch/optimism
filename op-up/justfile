set shell := ["/bin/bash", "-cu"]

# Usage: just -f op-up/justfile deploy chain_id=901
deploy chain_id:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env && {{justfile_directory()}}/deploy-sepolia.sh {{chain_id}}

# Usage: just -f op-up/justfile deploy2 chain_id_a=901 chain_id_b=902
deploy2 chain_id_a chain_id_b:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env && {{justfile_directory()}}/deploy-sepolia.sh {{chain_id_a}} {{justfile_directory()}}/artifacts/chain-{{chain_id_a}}
    set -euo pipefail; WAIT="${OP_UP_DEPLOY_WAIT:-30}"; echo "Waiting ${WAIT}s before second deploy to avoid nonce contention..."; sleep "${WAIT}"
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env && {{justfile_directory()}}/deploy-sepolia.sh {{chain_id_b}} {{justfile_directory()}}/artifacts/chain-{{chain_id_b}}

# Usage: just -f op-up/justfile run stop_after=120
run stop_after:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env && cd {{justfile_directory()}} && OP_EXTERNAL_L1=1 OP_SV2_CONFIRM_DEPTH=2 OP_UP_STOP_AFTER={{stop_after}} go run .

# Usage: just -f op-up/justfile run2 stop_after=420
run2 stop_after:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env && cd {{justfile_directory()}} && \
    OP_L2_CHAIN_IDS="${OP_L2_CHAIN_IDS:-901,902}" \
    OP_SV2_CONFIRM_DEPTH="${OP_SV2_CONFIRM_DEPTH:-2}" \
    OP_UP_STOP_AFTER={{stop_after}} \
    OP_L2_ROLLUP_PATH_901="${OP_L2_ROLLUP_PATH_901:-$PWD/artifacts/chain-901/rollup.json}" \
    OP_L2_GENESIS_PATH_901="${OP_L2_GENESIS_PATH_901:-$PWD/artifacts/chain-901/l2_genesis.json}" \
    OP_L2_ROLLUP_PATH_902="${OP_L2_ROLLUP_PATH_902:-$PWD/artifacts/chain-902/rollup.json}" \
    OP_L2_GENESIS_PATH_902="${OP_L2_GENESIS_PATH_902:-$PWD/artifacts/chain-902/l2_genesis.json}" \
    OP_EXTERNAL_L1=1 go run .

# Usage: just -f op-up/justfile clean
clean:
    set -euo pipefail; rm -rf {{justfile_directory()}}/artifacts/* {{justfile_directory()}}/logs/* || true

# Combined flow: clean -> deploy -> run
up chain_id stop_after:
    set -euo pipefail; just -f {{justfile_directory()}}/justfile clean
    set -euo pipefail; just -f {{justfile_directory()}}/justfile deploy {{chain_id}}
    set -euo pipefail; just -f {{justfile_directory()}}/justfile run {{stop_after}}
BINARY := "op-up"

# Default target
default: build

# Build target
build: artifacts
    mkdir -p bin
    go build -o ./bin/{{ BINARY }} .

# Build dependency
artifacts:
    just ../op-deployer/copy-contract-artifacts

# Clean target
# (merged into the main clean recipe above)
