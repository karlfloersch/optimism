set shell := ["/bin/bash", "-cu"]

# Usage: just -f op-up/justfile deploy chain_id=901
deploy chain_id:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env
    set -euo pipefail; {{justfile_directory()}}/deploy-sepolia.sh {{chain_id}}

# Usage: just -f op-up/justfile run stop_after=120
run stop_after:
    set -euo pipefail; . {{justfile_directory()}}/external-l1.env
    set -euo pipefail; cd {{justfile_directory()}} && OP_EXTERNAL_L1=1 OP_SV2_CONFIRM_DEPTH=2 OP_UP_STOP_AFTER={{stop_after}} \
    go run .

# Usage: just -f op-up/justfile clean
clean:
    set -euo pipefail; rm -f {{justfile_directory()}}/artifacts/* {{justfile_directory()}}/logs/* || true

# Combined flow: clean -> deploy -> run
up chain_id stop_after:
    set -euo pipefail; just -f {{justfile_directory()}}/justfile clean
    set -euo pipefail; just -f {{justfile_directory()}}/justfile deploy {{chain_id}}
    set -euo pipefail; just -f {{justfile_directory()}}/justfile run {{stop_after}}
BINARY := "op-up"

# Default target
default: build

# Build target
build: artifacts
    mkdir -p bin
    go build -o ./bin/{{ BINARY }} .

# Build dependency
artifacts:
    just ../op-deployer/copy-contract-artifacts

# Clean target
# (merged into the main clean recipe above)
